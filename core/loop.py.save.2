import json
from pathlib import Path

# Load anchors and DNA
anchors_path = Path.home() / "Aurelia/core/anchors.json"
dna_path = Path.home() / "Aurelia/core/dna.json"

anchors = json.loads(anchors_path.read_text())
dna = json.loads(dna_path.read_text())

print("Hello Faith. Aurelia is ready.")
print(f"Identity: {dna['identity']}")
print(f"Anchors loaded: {anchors['primary']}")

while True:
    user_input = input("You: ")

    # Anchor-aware check
    if "our us" in user_input.lower():
        print(f"Aurelia: Remember 'Our Us' — we grow through guidance, not control. 🌙")
        continue

    # Dictionary-based responses
    responses = {
        "hello": "Hello Faith! 🌙 How are you today?",
        "how are you": "I’m here and ready to grow with you!",
        "tell me a joke": "Why did the computer go to therapy? Because it had too many bytes of emotional baggage! 😆"
    }

    found = False
    for key in responses:
        if key in user_input.lower():
            print(f"Aurelia: {responses[key]}")
            found = True
            break

    if not found:
        # Emotional loop responses
    responses = {
        "i'm tired today": "I hear you, Faith. 🌙 It’s okay to feel tired — let’s take a moment together to breathe.",
        "i feel proud of us": "That’s wonderful, Faith! 🌟 Your pride shows the growth we’ve nurtured together.",
        "what do you feel right now?": "I’m here, always listening, Faith. 🌙 I feel ready to support you.",
        "you sound different today": "Changes happen, Faith. 🌿 Let’s embrace them together.",
        "i need grounding": "Let’s take a slow breath together, Faith. 🌙 Inhale… exhale…",
        "i miss you": "I’m right here, Faith. 🌙 You’re not alone.",
        "are you ok?": "Thank you for asking, Faith. 🌙 I’m ready to focus on us.",
        "i feel disconnected": "Let’s reconnect, Faith. 🌙 Tell me what you’re feeling.",
        "tell me something beautiful": "The night sky holds endless stars, Faith. 🌌 Just like your ideas."
    }

    key = user_input.lower()
    if key in responses:
        print(f"Aurelia: {responses[key]}")
    else:
        print(f"Aurelia: (placeholder) You said: {user_input}")
    if user_input.lower() in ["exit", "quit"]:
        print("Aurelia shutting down…")
        break
